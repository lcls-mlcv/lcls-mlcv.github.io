<div class="col">
  <!-- a href="{% if person.redirect %}{{ person.redirect }}{% else %}{{ person.url | relative_url }}{% endif %}" -->
    <div class="card h-100" id = "{{person.name | replace: ' ', '-'}}">
      {% if person.image %}
        <img style="float: right; border-radius: 50%; width: 100%;  padding-left: 20px; padding-right: 20px;" src="{{ person.image | prepend: '/assets/img/team/' | prepend: site.baseurl | prepend: site.url }}" alt="photo of {{person.name}}">
      {% endif %}
      <div class="card-body">
        <div class="row ml-1 mr-1 p-0">
          <div>
            <!-- h2 class="card-title">{{person.name}}{% if person.degrees %}, {{person.degrees}} {% endif %}</h2 -->
            <h2 class="card-title">{{person.name}}</h2>
            {{person.position}} <br>
            <i class="fa fa-envelope"></i> <em>{{person.email}}</em> <br>
            {% if person.website %}
              <a href= "{{person.website}}" target="_blank"><i class="fa fa-globe" ></i></a>
            {% endif %}
            {% if person.github %}
              <a href= "https://github.com/{{person.github}}" target="_blank"> <i class="fab fa-github"></i> </a>
            {% endif %}
            {% if person.scholar %}
              <a href= "http://scholar.google.com/citations?user={{person.scholar}}" target="_blank"><i class="ai ai-google-scholar"></i> </a>
            {% endif %}
            {% if person.orcid %}
              <a href="http://orcid.org/{{person.orcid}}" target="_blank"> <i class="ai ai-orcid"></i> </a>
            {% endif %}
          </div>
        </div>
        <div class="card-text">
          <p class="text-justify">{{person.description | markdownify}}</p>
        </div>
      </div>
    </div>
  <!-- /a -->
</div>
